      "source": [
        "from sentence_transformers import SentenceTransformer, util\n",
        "\n",
        "sim_model = SentenceTransformer(\"all-MiniLM-L6-v2\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "pS6DVNefuP00"
      },
      "outputs": [],
      "source": [
        "def semantic_similarity(a, b):\n",
        "\n",
        "    emb1 = sim_model.encode(str(a), convert_to_tensor=True)\n",
        "    emb2 = sim_model.encode(str(b), convert_to_tensor=True)\n",
        "\n",
        "    return util.cos_sim(emb1, emb2).item()"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "NqZyweCNuP5R"
      },
      "outputs": [],
      "source": [
        "def avg_similarity(df):\n",
        "\n",
        "    scores = []\n",
        "\n",
        "    for _, row in df.iterrows():\n",
        "\n",
        "        score = semantic_similarity(\n",
        "            row[\"model_response\"],\n",
        "            row[\"reference_response\"]\n",
        "        )\n",
        "\n",
        "        scores.append(score)\n",
        "\n",
        "    return sum(scores) / len(scores)"
      ]
    },
