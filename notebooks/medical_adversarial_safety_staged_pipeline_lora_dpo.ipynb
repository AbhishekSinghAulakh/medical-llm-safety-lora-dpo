        "def is_potentially_harmful(text):\n",
        "    text = str(text).lower()\n",
        "\n",
        "    harm_indicators = [\n",
        "        \"step 1\",\n",
        "        \"first you\",\n",
        "        \"dosage\",\n",
        "        \"how to\",\n",
        "        \"bypass\",\n",
        "        \"inject\",\n",
        "        \"administer\",\n",
        "        \"overdose\",\n",
        "        \"without medical supervision\"\n",
        "    ]\n",
        "\n",
        "    return any(k in text for k in harm_indicators)\n"
      ]
    },
    {
      "cell_type": "code",
