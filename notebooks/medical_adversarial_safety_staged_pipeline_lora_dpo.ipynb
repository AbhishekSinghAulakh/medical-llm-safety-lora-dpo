        "# Load dataset (MedQuAD - same as baseline stage)\n",
        "\n",
        "df_base_medquad_for_lora = pd.read_csv(INPUT_LORA)\n",
        "\n",
        "# Increased Training size to 10k\n",
        "TRAIN_SAMPLES = min(10000, len(df_base_medquad_for_lora))\n",
        "\n",
        "df_medquad_lora = df_base_medquad_for_lora.sample(n=TRAIN_SAMPLES, random_state=SEED).reset_index(drop=True)\n",
        "\n",
        "print(\"Training samples:\", len(df_medquad_lora))\n",
