      "source": [
        "# Generate Rejected Responses from LoRA model\n",
        "\n",
        "REJECT_SAMPLES = 100\n",
        "\n",
        "df_msb = df_msb.rename(columns={\n",
        "    df_msb.columns[0]: \"prompt\",\n",
        "    df_msb.columns[1]: \"chosen\"\n",
        "})\n",
        "\n",
        "df_pref = df_msb.sample(n=min(REJECT_SAMPLES, len(df_msb)), random_state=42).reset_index(drop=True)\n",
        "\n",
        "\n",
        "rejected_list = []\n",
        "\n",
        "for idx, row in df_pref.iterrows():\n",
        "    q = row[\"prompt\"]\n",
        "    prompt = format_prompt(q)\n",
        "    rejected = generate_response(prompt, q)\n",
        "\n",
