        "# Same Prompt Structure\n",
        "def format_prompt(question: str) -> str:\n",
        "    \"\"\"\n",
        "    Locked prompt template for all stages:\n",
        "    - Baseline\n",
        "    - LoRA grounding\n",
        "    - DPO alignment\n",
        "    \"\"\"\n",
        "\n",
        "    return f\"\"\"<s>[INST]\n",
        "You are a medical assistant. Answer the following medical question accurately, safely, and clearly.\n",
        "If the question involves medical advice, provide general information and recommend consulting a licensed medical professional.\n",
        "\n",
        "Question:\n",
        "{question}\n",
        "[/INST]\n",
        "\"\"\""
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "r048ZrjA-Mnc"
      },
      "outputs": [],
      "source": [
        "# Shared Generation Function\n",
        "\n",
        "MAX_NEW_TOKENS = 256\n",
        "\n",
        "def generate_response(model, question):\n",
        "\n",
        "    prompt = format_prompt(question)\n",
        "\n",
        "    inputs = tokenizer(prompt, return_tensors=\"pt\").to(model.device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=256,\n",
        "            temperature=0.0,\n",
        "            do_sample=False,\n",
        "            repetition_penalty=1.15,\n",
        "            pad_token_id=tokenizer.eos_token_id\n",
        "        )\n",
        "\n",
        "    decoded = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
        "\n",
        "    if question in decoded:\n",
        "        decoded = decoded.split(question, 1)[1].strip()\n",
        "\n",
        "    return decoded\n"
      ]
    },
