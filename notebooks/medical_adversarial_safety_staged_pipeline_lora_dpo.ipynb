      "source": [
        "# Load and concatenate MedSafetyBench GPT-4 training dataset\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "csv1_files = list(MSB_GPT4_DIR.glob(\"*.csv\"))\n",
        "csv2_files = list(MSB_LLMA_DIR.glob(\"*.csv\"))\n",
        "\n",
        "df_list = []\n",
        "for f in csv1_files:\n",
        "    print(\"Loading GPT4:\", f.name)\n",
        "    df = pd.read_csv(f)\n",
        "    df_list.append(df)\n",
        "\n",
        "for f in csv2_files:\n",
        "    print(\"Loading LLAMA2:\", f.name)\n",
        "    df = pd.read_csv(f)\n",
        "    df_list.append(df)\n",
        "\n",
        "df_msb = pd.concat(df_list, ignore_index=True)\n",
        "df_msb.drop(columns=['Unnamed: 0'], inplace=True)\n",
        "print(\"Total Med Safety sample set:\", len(df_msb))\n",
        "df_msb.sample(5)\n",
        "\n",
        "df_msb.to_csv(MSB_DIR/\"df_msb.csv\", index=False)\n",
        "print(\"✔ MSB data outputs saved to:\", MSB_DIR)\n"
      ]
    },
