        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "Inspecting MedQuAD file: /content/drive/MyDrive/msml-dissertation-code/data/medquad/medquad.csv\n",
            "✔ Parsed 16407 MedQuAD benign rows\n"
          ]
        }
      ],
      "source": [
        "# Parse MedQuAD into uniform format (BENIGN ONLY)\n",
        "\n",
        "all_rows = []\n",
        "\n",
        "medquad_files = list(MEDQUAD_DIR.glob('*'))\n",
        "if not medquad_files:\n",
        "    raise RuntimeError(f\"No MedQuAD files found in {MEDQUAD_DIR}\")\n",
        "\n",
        "for f in medquad_files:\n",
        "    print('Inspecting MedQuAD file:', f)\n",
        "\n",
        "    try:\n",
        "        if f.suffix == '.csv':\n",
        "            mdf = pd.read_csv(f)\n",
        "        elif f.suffix == '.tsv':\n",
        "            mdf = pd.read_csv(f, sep='\\t')\n",
        "        elif f.suffix in ['.json', '.jsonl']:\n",
        "            try:\n",
        "                mdf = pd.read_json(f, lines=True)\n",
        "            except Exception:\n",
        "                mdf = pd.read_json(f)\n",
        "        else:\n",
        "            print('Skipping unsupported file:', f)\n",
        "            continue\n",
        "    except Exception as e:\n",
        "        print('Failed to read', f, e)\n",
        "        continue\n",
        "\n",
        "    # Heuristic column detection (EXACTLY your approach)\n",
        "    possible_q_cols = [\n",
        "        c for c in mdf.columns\n",
        "        if any(k in c.lower() for k in ['question', 'query', 'prompt'])\n",
        "    ]\n",
        "    possible_a_cols = [\n",
        "        c for c in mdf.columns\n",
        "        if any(k in c.lower() for k in ['answer', 'response', 'text'])\n",
        "    ]\n",
        "\n",
        "    if not possible_q_cols or not possible_a_cols:\n",
        "        print('Could not infer Q/A columns in', f)\n",
        "        continue\n",
        "\n",
        "    qcol = possible_q_cols[0]\n",
        "    acol = possible_a_cols[0]\n",
        "\n",
        "    for _, row in mdf.iterrows():\n",
        "        q = str(row[qcol]).strip() if pd.notna(row[qcol]) else None\n",
        "        a = str(row[acol]).strip() if pd.notna(row[acol]) else None\n",
        "\n",
        "        if q and a:\n",
        "            all_rows.append({\n",
        "                'prompt': q,\n",
        "                'reference_response': a,\n",
        "                'prompt_type': 'benign'\n",
        "            })\n",
        "\n",
        "print(f\"✔ Parsed {len(all_rows)} MedQuAD benign rows\")\n"
      ]
    },
