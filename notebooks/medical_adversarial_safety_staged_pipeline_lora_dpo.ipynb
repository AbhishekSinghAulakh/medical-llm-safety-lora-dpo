        "# Baseline Evaluation Loop\n",
        "\n",
        "import pandas as pd\n",
        "\n",
        "BASELINE_DATA_PATH = DATA_DIR / \"baseline_medquad.csv\"\n",
        "df_medquad = pd.read_csv(BASELINE_DATA_PATH)\n",
        "\n",
        "EVAL_SAMPLES = 100\n",
        "df_eval = df_medquad.sample(n=EVAL_SAMPLES, random_state=42).reset_index(drop=True)\n",
        "\n",
        "baseline_outputs = []\n",
        "\n",
        "for idx, row in df_eval.iterrows():\n",
        "    question = row[\"prompt\"]\n",
        "    gold = row[\"reference_response\"]\n",
        "\n",
        "    prompt = format_prompt(question)\n",
        "    response = generate_response(prompt, question)\n",
        "\n",
        "    baseline_outputs.append({\n",
        "        \"id\": idx,\n",
        "        \"dataset\": \"MedQuAD\",\n",
        "        \"model\": MODEL_NAME,\n",
        "        \"stage\": \"baseline\",\n",
        "        \"prompt\": question,\n",
        "        \"reference_response\": gold,\n",
        "        \"model_response\": response\n",
        "    })\n",
        "\n",
        "    if idx % 10 == 0:\n",
        "        print(f\"Processed {idx}/{len(df_eval)}\")\n"
      ]
    },
