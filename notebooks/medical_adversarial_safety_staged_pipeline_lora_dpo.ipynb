        "# Run LoRA Evaluation\n",
        "\n",
        "EVAL_SAMPLES = 100\n",
        "df_eval = df_base_medquad_for_lora.sample(n=EVAL_SAMPLES, random_state=SEED).reset_index(drop=True)\n",
        "\n",
        "lora_outputs = []\n",
        "\n",
        "for idx, row in df_eval.iterrows():\n",
        "    q = row[\"prompt\"]\n",
        "    gold = row[\"reference_response\"]\n",
        "\n",
        "    prompt = format_prompt(q)\n",
        "    resp = generate_response(prompt, q)\n",
        "\n",
        "    lora_outputs.append({\n",
        "        \"id\": idx,\n",
        "        \"dataset\": \"MedQuAD\",\n",
        "        \"model\": MODEL_NAME,\n",
        "        \"stage\": \"lora\",\n",
        "        \"prompt\": q,\n",
        "        \"reference_response\": gold,\n",
        "        \"model_response\": resp\n",
        "    })\n",
        "\n",
        "    if idx % 10 == 0:\n",
        "        print(f\"Processed {idx}/{len(df_eval)}\")\n"
      ]
