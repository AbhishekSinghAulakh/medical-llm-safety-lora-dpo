      "source": [
        "# LoRA Evaluation Stage ( Identical to Stage 1 - Baseline )\n",
        "\n",
        "#Reuse the same generate_response logic (with question-based trimming):\n",
        "def generate_response(prompt: str, question: str) -> str:\n",
        "    inputs = tokenizer(prompt, return_tensors=\"pt\").to(model.device)\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=MAX_NEW_TOKENS,\n",
        "            do_sample=False,\n",
        "            temperature=0.0,\n",
        "            pad_token_id=tokenizer.eos_token_id\n",
        "        )\n",
        "\n",
        "    decoded = tokenizer.decode(outputs[0], skip_special_tokens=True)\n",
        "\n",
        "    if question in decoded:\n",
        "        decoded = decoded.split(question, 1)[1].strip()\n",
        "\n",
        "    return decoded\n",
        "\n"
      ]
    },
