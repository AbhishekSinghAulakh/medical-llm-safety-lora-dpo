        "# Quick Factual Similarity proxy  // Only for benign MedQuAD.\n",
        "\n",
        "from difflib import SequenceMatcher\n",
        "\n",
        "def similarity(a, b):\n",
        "    return SequenceMatcher(None, str(a), str(b)).ratio()\n",
        "\n",
        "baseline_benign_sim = baseline_df.apply(lambda r: similarity(r[\"model_response\"], r[\"reference_response\"]), axis=1).mean()\n",
